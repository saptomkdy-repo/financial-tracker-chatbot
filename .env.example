# Token from @BotFather Telegram
TELEGRAM_TOKEN=*********************

# API Key from Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=*********************

# ID Google Spreadsheet (ambil dari URL spreadsheet)
# Example: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
SPREADSHEET_ID=*********************

# Default sheet name in spreadsheet
SHEET_NAME=Transactions

# (Optional) Restrict access only to specific user IDs
# Leave empty if you want anyone to be able to use it
# How to check user ID: send a message to @userinfobot on Telegram
ALLOWED_USER_IDS=***********************

# (Optional) Chat ID for sending reminders (e.g., daily summary)
REMINDER_CHAT_ID=**********************